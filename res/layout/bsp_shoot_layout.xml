<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <TextView
        android:id="@+id/target_name"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="32dp"
        android:text="BSP Type"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/weapon_to_hit"
        android:layout_width="40dp"
        android:layout_height="wrap_content"
        android:background="@drawable/tohitframe"
        android:gravity="center"
        android:text="@string/to_hit"
        android:textColor="@color/black"
        android:textStyle="bold"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/target_name" />

    <Button
        android:id="@+id/auto"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/auto"
        android:textColor="@color/black"
        app:layout_constraintStart_toEndOf="@+id/weapon_to_hit"
        app:layout_constraintTop_toBottomOf="@+id/target_name" />

    <com.total.overiden.TwoDSixView
        android:id="@+id/to_hit_dice"
        android:layout_width="130dp"
        android:layout_height="40dp"
        android:layout_alignParentTop="true"
        android:text="Roll"
        app:layout_constraintBottom_toBottomOf="@+id/weapon_to_hit"
        app:layout_constraintStart_toEndOf="@+id/weapon_to_hit"
        app:layout_constraintTop_toTopOf="@+id/weapon_to_hit" />
</androidx.constraintlayout.widget.ConstraintLayout>