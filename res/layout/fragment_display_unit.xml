<?xml version="1.0" encoding="utf-8"?>
    <androidx.constraintlayout.widget.ConstraintLayout
        xmlns:android="http://schemas.android.com/apk/res/android"
        xmlns:app="http://schemas.android.com/apk/res-auto"
        xmlns:tools="http://schemas.android.com/tools"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        tools:context=".DisplayUnitFragment">

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/force_list"
        android:layout_width="500dp"
        android:layout_height="600dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/name_filter" />
    <Button
        android:id="@+id/overview"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:text="Overview"
        app:layout_constraintStart_toStartOf="@+id/mechContainerView"
        app:layout_constraintTop_toTopOf="parent" />
    <Button
        android:id="@+id/armour"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Armour"
        app:layout_constraintStart_toEndOf="@+id/overview"
        app:layout_constraintTop_toTopOf="parent" />
    <Button
        android:id="@+id/config"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/configure_tics"
        app:layout_constraintStart_toEndOf="@+id/armour"
        app:layout_constraintTop_toTopOf="parent" />

    <Button
        android:id="@+id/equipment"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/equipment"
        app:layout_constraintStart_toEndOf="@+id/config"
        app:layout_constraintTop_toTopOf="parent" />

    <Button
        android:id="@+id/delete"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/delete"
        app:layout_constraintEnd_toStartOf="@+id/add_mtf"
        app:layout_constraintTop_toTopOf="@+id/add_mtf" />

    <EditText
        android:id="@+id/name_filter"
        android:layout_width="150dp"
        android:layout_height="wrap_content"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />
    <Spinner
        android:id="@+id/unit_type"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintStart_toEndOf="@+id/name_filter"
        app:layout_constraintTop_toTopOf="@+id/name_filter" />

    <Button
        android:id="@+id/filter"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/filter"
        app:layout_constraintStart_toEndOf="@+id/unit_type"
        app:layout_constraintTop_toTopOf="@+id/name_filter" />
    <com.total.overiden.LockButton
        android:id="@+id/lock_unit"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintStart_toEndOf="@+id/equipment"
        app:layout_constraintTop_toTopOf="parent" />
    <FrameLayout
        android:id="@+id/mechContainerView"
        android:layout_width="500dp"
        android:layout_height="575dp"
        app:layout_constraintStart_toEndOf="@+id/force_list"
        app:layout_constraintTop_toBottomOf="@+id/armour">

    </FrameLayout>

    <Button
        android:id="@+id/add_mtf"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/add_from_mtf"
        app:layout_constraintEnd_toEndOf="@+id/force_list"
        app:layout_constraintTop_toBottomOf="@+id/force_list" />
</androidx.constraintlayout.widget.ConstraintLayout>

